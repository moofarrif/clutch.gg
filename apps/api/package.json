{
  "name": "@clutch/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "NODE_ENV=development node --require @swc-node/register --watch src/main.ts",
    "start": "node dist/main",
    "start:prod": "NODE_ENV=production node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/database/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clutch/shared": "workspace:*",
    "@nestjs/bullmq": "^11",
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^11",
    "@nestjs/passport": "^11",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11",
    "@nestjs/swagger": "^11",
    "@nestjs/throttler": "^6",
    "@nestjs/websockets": "^11",
    "bcryptjs": "^2",
    "bullmq": "^5",
    "cloudinary": "^2.9.0",
    "drizzle-orm": "^0.44",
    "expo-server-sdk": "^6.1.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "ioredis": "^5",
    "multer": "^2.1.1",
    "nestjs-pino": "^4",
    "nestjs-zod": "^4",
    "passport": "^0.7",
    "passport-jwt": "^4",
    "pino-http": "^10",
    "postgres": "^3",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "socket.io": "^4",
    "zod": "^3"
  },
  "devDependencies": {
    "@clutch/tsconfig": "workspace:*",
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.24",
    "@types/bcryptjs": "^2",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/passport-jwt": "^4",
    "@types/supertest": "^6",
    "drizzle-kit": "^0.31",
    "pino-pretty": "^13",
    "supertest": "^7",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3"
  }
}